//やること：マップ制作。気が向いたら新しいNPCなんかも作るかも。

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <conio.h>
#include <windows.h>
#include <time.h>
#include <math.h>

FILE *fp;

typedef struct
{
	int x;
	int y;
	int type;
	int in;
	int nf;
} NPC;

int d[32][18] = {0};//画面
char map[6] = "0.map";
int I = 5;//コマンド
int X = 16, Y = 9;//座標
int debug = 0;//デバッグ用
int power = 1;
char raw[16];
int timer = 0;
int ncn = 0;
NPC *npc = NULL;

int UI();
int COM();
int ML();
int go();
int NC(int);
int NRM(int);
int NCO(int);

int main(void)
{
	system("cls");

	fp = fopen(map, "rb");

	ML();
	d[X][Y] = 1;
	srand((unsigned long int)time(NULL));

	while(power)
	{
		go();
		UI();

		if(debug != 0) printf("\nX=%2d, Y=%2d, NPC=%2d", X, Y, ncn);
		else printf("\n                  ");

		if(_kbhit()) I = _getch() - '0';
 
		for(int i = 0; i < ncn; i++)
		{
			NC(i);
			if(npc[i].nf)
			{
				d[npc[i].x][npc[i].y] = 0;
				NRM(i);
				if(timer >= 1200) NCO(i);

				if(d[npc[i].x][npc[i].y] == 2 || d[npc[i].x][npc[i].y] == 4)
				{
					d[npc[i].x][npc[i].y] = d[npc[i].x][npc[i].y] == 2 ? 2 : 4;
					npc[i].in = npc[i].in == 3 ? 1 : (npc[i].in == 4 ? 2 : (npc[i].in == 1 ?  3: 4));
					NCO(i);
					d[npc[i].x][npc[i].y] = 3;
				}
				else
				{
					npc[i].x = npc[i].x < 32 ? (-1 < npc[i].x ? npc[i].x : 31) : 0;
					npc[i].y = npc[i].y < 18 ? (-1 < npc[i].y ? npc[i].y : 17) : 0;
					d[npc[i].x][npc[i].y] = 3;
				}
			}
		}
		if(timer >= 1200) timer = 0;

		d[X][Y] = 0;
		COM();

		if(d[X][Y] == 4)
		{
			int EX, EY, ET;

			fseek(fp, 288, SEEK_SET);
			while(1)
			{
				EX = fgetc(fp);
				EY = fgetc(fp);
				if(EX == X && EY == Y)
				{
					ET= fgetc(fp);
					break;
				}
				else while(1)
				{
					EX = fgetc(fp);
					if(EX == 254) break;
				}
				if(EX == 255 && EX == 253) break;
			}

			switch(ET)
			{
				default:
				break;

				case 1://マップ移動できた。
					X = X <= 30 ? (1 <= X ? X : 30) : 1;
					Y = Y <= 16 ? (1 <= Y ? Y : 16) : 1;
					d[X][Y] = 1;
					map[0] = fgetc(fp) + '0';
					fclose(fp);
					fp = fopen(map, "rb");
					ML();
				break;
			}
		}

		if(d[X][Y] != 2)
		{
			X = X < 32 ? (-1 < X ? X : 31) : 0;
			Y = Y < 18 ? (-1 < Y ? Y : 17) : 0;
			d[X][Y] = 1;
		}
		else
		{
			d[X][Y] == 2;
			I = I == 2 ? 8 : (I == 4 ? 6 : (I == 6 ? 4 : 2));
			COM();
			d[X][Y] = 1;
		}

		I = 5;
		timer++;
	}
	fclose(fp);

	return 0;
}



int UI()
{
	
	char buffer[2048] = ""; 
	char line[128];

	strcat(buffer, "================================================================\n");

	for(int i = 0; i < 18; i++)
	{
		line[0] = '\0';
		for(int k = 0; k < 32; k++)
		{
			switch(d[k][i])
			{
				case 0: strcat(line, ",,"); break;
				case 1: strcat(line, "@@"); break;
				case 2: strcat(line, "[]"); break;
				case 3: strcat(line, "##"); break;
				case 4: strcat(line, "!!"); break;
			}
		}
		strcat(line, "\n");
		strcat(buffer, line);
	}

	strcat(buffer, "================================================================");

	printf("%s", buffer);
	return 0;
}

int COM()
{
	switch(I)
	{
		case 9:
			if(debug == 0) debug = 1;
			else debug = 0;
		break;

		case 0:
			power = 0;
		break;

		case 5:
		break;

		case 8:
			Y--;
		break;

		case 6:
			X++;
		break;

		case 2:
			Y++;
		break;

		case 4:
			X--;
		break;
	}
	return 0;
}

int ML()
{
	if(npc != NULL)
	{
		free(npc);
		npc = NULL;
	}

	fseek(fp, 0, SEEK_SET);
	for(int i = 0; i < 18; i++)
	{
		fread(raw, 1, 16, fp);

		for(int k = 0; k < 32; k += 2)
		{
			d[k][i] = raw[k / 2] >> 4;
			d[k + 1][i] = raw[k / 2] % 16;
		}
	}

	ncn = 0;
	int c;
	fseek(fp, 0, SEEK_SET);
	while((c = fgetc(fp)) != 253 && c != 255 && c != EOF);

	long ds = 0;
	if((unsigned char)c == 253)
	{
		ds = ftell(fp); 

		while((c = fgetc(fp)) != 255 && c != EOF) if(c == 254) ncn++;
	}

	npc = (NPC *)malloc(sizeof(NPC) * (ncn > 0 ? ncn : 1));

	fseek(fp, ds, SEEK_SET);
	for(int i = 0; i < ncn; i++)
	{
		npc[i].x = fgetc(fp);
		npc[i].y = fgetc(fp);
		npc[i].type = fgetc(fp);
		fgetc(fp);
		npc[i].in = 0;
		npc[i].nf = 1;
		d[npc[i].x][npc[i].y] = 3;
	}

	return 0;
}

int go()
{
	COORD coord;
	coord.X = 0;
	coord.Y = 0;
	SetConsoleCursorPosition(GetStdHandle(STD_OUTPUT_HANDLE), coord);

	return 0;
}

int NC(int i)
{
	if(npc[i].x == X && npc[i].y == Y) npc[i].nf = 0;

	return 0;	
}

int NRM(int i)
{
	npc[i].in = rand() % 5;

	return 0;
}

int NCO(int i)
{
	int Nx = npc[i].x, Ny = npc[i].y;
	
	if(fabs(npc[i].x - X) <= 3 && fabs(npc[i].y - Y) <= 3)
	{
//相対座標を出していろいろやる。
		if(fabs(npc[i].x - X) <= fabs(npc[i].y - Y))
		{
			if(npc[i].y - Y < 0)
			{
				npc[i].in = 1;//up
			}
			else
			{
				npc[i].in = 3;//down
			}
		}
		else
		{
			if(npc[i].x - X < 0)
			{
				npc[i].in = 4;//left
			}
			else
			{
				npc[i].in = 2;//right
			}
		}
	}

	switch(npc[i].in)
	{
		case 0:
		break;

		case 1:
			npc[i].y -= 1;//上
		break;

		case 2:
			npc[i].x += 1;//右
		break;

		case 3:
			npc[i].y += 1;//下
		break;

		case 4:
			npc[i].x -= 1;//左
		break;
	}

	if(fabs(npc[i].x - X) <= 3 && fabs(npc[i].y - Y) <= 3 && (d[npc[i].x][npc[i].y] == 2 || d[npc[i].x][npc[i].y] == 4))
	{
		npc[i].x = Nx;
		npc[i].y = Ny;
	}

	return 0;
}




